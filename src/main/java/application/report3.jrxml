	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="edvora"/>
	<style name="Title" fontName="Arial" fontSize="26.0" bold="true"/>
	<style name="SubTitle" forecolor="#666666" fontName="Arial" fontSize="18.0"/>
	<style name="Column header" forecolor="#666666" fontName="Arial" fontSize="12.0" bold="true"/>
	<style name="Detail" fontName="Arial" fontSize="12.0"/>
	<query language="SQL"><![CDATA[SELECT 
    u.firstname || ' ' || u.lastname AS teacher_name,
    COUNT(c.course_id) AS course_count
FROM public."User" u
JOIN public.teacher t ON u.email = t.email
LEFT JOIN public.course c ON t.email = c.email_teacher
GROUP BY u.firstname, u.lastname]]></query>
	<field name="teacher_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="teacher_name"/>
		<property name="com.jaspersoft.studio.field.label" value="teacher_name"/>
	</field>
	<field name="course_count" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="course_count"/>
