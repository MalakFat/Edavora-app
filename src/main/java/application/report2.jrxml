	<dataset name="PieChartDataset" uuid="39581794-7f4c-48d6-8f6a-b421776f515c"/>
	<query language="SQL"><![CDATA[SELECT 
    u.firstname || ' ' || u.lastname AS student_name,
    c.name_course AS course_name,
    b.student_email AS student_email
from public.banned b
JOIN public.course c ON b.course_id = c.course_id
JOIN public.student s ON b.student_email = s.email
JOIN public."User" u ON s.email = u.email
order by student_email]]></query>
	<field name="student_email" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="student_email"/>
		<property name="com.jaspersoft.studio.field.label" value="student_email"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="banned"/>
	</field>
	<field name="course_name" class="java.lang.String">
