	<query language="SQL"><![CDATA[SELECT 
    u.email,
    MAX(u.firstname) || ' ' || MAX(u.lastname) AS "Teacher Name",
    MAX(u.gender) AS Gender,
    MAX(t.salary) AS Salary,
    COUNT(c.course_id) AS Course_count
FROM public.teacher t
INNER JOIN public."User" u
    ON u.email = t.email
LEFT JOIN public.course c
    ON u.email = c.email_teacher
WHERE u.user_type = 2
GROUP BY u.email
ORDER BY Course_count DESC
]]></query>
