	<style name="Detail" fontName="Arial" fontSize="12.0"/>
	<query language="SQL"><![CDATA[SELECT c.name_course AS course_name,
	COUNT( s.student_email) AS student_count,
	c.course_id
FROM public.course c
	LEFT JOIN public.study s ON 
	 c.course_id = s.course_id 
GROUP BY c.course_id,
	c.name_course]]></query>
