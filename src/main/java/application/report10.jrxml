	<dataset name="PieChartDataset" uuid="39581794-7f4c-48d6-8f6a-b421776f515c"/>
	<query language="SQL"><![CDATA[SELECT 
    u.firstname || ' ' || u.lastname AS full_name,
    'Student' AS user_type
FROM public."User" u
JOIN public.student s ON u.email = s.email
UNION
SELECT 
    u.firstname || ' ' || u.lastname AS full_name,
    'Teacher' AS user_type
FROM public."User" u
JOIN public.teacher t ON u.email = t.email
order by user_type]]></query>
	<field name="user_type" class="java.lang.String">
