	<style name="Detail" fontName="Arial" fontSize="12.0"/>
	<query language="SQL"><![CDATA[SELECT 
    LOWER(c.name_course) AS course_name,
    COUNT(DISTINCT t.email) AS teacher_count
FROM public.course c
JOIN public.teacher t ON c.email_teacher = t.email
JOIN public."User" u ON t.email = u.email
GROUP BY LOWER(c.name_course)]]></query>
	<field name="course_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="course_name"/>
		<property name="com.jaspersoft.studio.field.label" value="course_name"/>
	</field>
