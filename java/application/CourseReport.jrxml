<jasperReport name="Waves_Landscape_1" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="e115bc59-fd0f-446b-a585-04725e27d7f0">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
