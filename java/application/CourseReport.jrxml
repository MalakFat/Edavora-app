	<style name="Detail" fontName="Arial" fontSize="12.0"/>
	<query language="SQL"><![CDATA[SELECT 
    MAX(c.name_course) AS "Course name",
    MAX(c.max_capacity) AS "Max Capacity",
    TO_CHAR(MAX(c.start_time), 'HH24:MI') || ' - ' || TO_CHAR(MAX(c.end_time), 'HH24:MI') AS "Course Time",
    MAX(u.firstname || ' ' || u.lastname) AS "Teacher name",
    COUNT(DISTINCT s.student_email) AS "Enrolled student",
    COUNT(DISTINCT b.student_email) AS "Banned student"
FROM public.course c
INNER JOIN public."User" u 
    ON u.email = c.email_teacher
LEFT JOIN public.study s 
    ON s.course_id = c.course_id
LEFT JOIN public.banned b
    ON b.course_id = c.course_id
GROUP BY c.course_id
ORDER BY "Course name"
]]></query>
