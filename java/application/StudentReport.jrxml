	<query language="SQL"><![CDATA[SELECT 
    u.email,
    MAX(u.firstname) || ' ' || MAX(u.lastname) AS full_name,
    MAX(u.gender) AS gender,
    MAX(u.age) AS age,
    COUNT(s.course_id) AS course_count
FROM public."User" u
LEFT JOIN public.study s
    ON u.email = s.student_email 
WHERE u.user_type = 1 
GROUP BY u.email
order by course_count desc
]]></query>
	<field name="email" class="java.lang.String">
